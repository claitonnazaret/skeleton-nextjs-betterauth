### Database Environment Variables
DATABASE_URL=

### Better Auth Config
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

### Email Configuration (Resend)
# Obtenha sua API key em: https://resend.com/api-keys
RESEND_API_KEY=

# Email do remetente (deve ser verificado no Resend)
# Para testes, use: onboarding@resend.dev
EMAIL_FROM=onboarding@resend.dev

# Nome de exibição do remetente
EMAIL_FROM_NAME=Minha Aplicação

# Email de reply-to (opcional)
EMAIL_REPLY_TO=